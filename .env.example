# Supabase（Project Settings > API から取得）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 管理画面ログイン（納品時にこちらで生成）
ADMIN_ID=
# bcryptハッシュ（平文パスワードではない）。生成例:
#   node -e "console.log(require('bcryptjs').hashSync('パスワード', 10))"
ADMIN_PASSWORD_HASH=

# セッション署名用のランダム文字列。生成例: openssl rand -base64 32
SESSION_SECRET=

# デプロイ後のURL（LINEへの通知メッセージ内リンクに使用）
APP_URL=https://example.vercel.app

# 以下はVercel環境変数には設定しない。
# LINEチャネルシークレット／アクセストークン、Claude APIキーは
# オーナーが /admin/settings 画面から入力・更新する運用のため、
# データベース（app_settings）側で管理する。
